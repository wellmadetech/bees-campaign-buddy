{
  "name": "campaignbuddybees",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:seed": "npm run db:seed --workspace=server",
    "render:build": "npm install && npm run build --workspace=@campaignbuddy/shared && npm run build --workspace=client && npm run build --workspace=server",
    "render:start": "node apps/server/dist/index.js"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.18.0"
  }
}
